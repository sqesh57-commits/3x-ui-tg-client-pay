# ================================================
# .env для Telegram-бота 3x-ui-tg-client-pay
# ================================================
# Значения берутся из .env репозитория 3x-ui-deploy-sq
# и из панели 3x-ui (раздел Inbounds → Reality)

# === Telegram ===
# От @BotFather
BOT_TOKEN=<токен_бота>
# От @BotFather (раздел Payments)
PAYMENT_TOKEN=<платёжный_токен>
# Telegram ID администраторов через запятую
ADMINS=<ваш_telegram_id>

# === 3x-ui Panel ===
# URL API панели.
# Если бот на том же сервере — используйте localhost + внутренний порт:
#   XUI_API_URL=http://localhost:{PANEL_INTERNAL_PORT}
# Если бот на другом сервере — внешний URL:
#   XUI_API_URL=https://{PANEL_SERVER_NAME}:{PANEL_ALT_PORT}
XUI_API_URL=http://localhost:<PANEL_INTERNAL_PORT>

# Домен панели (из .env деплоя: PANEL_SERVER_NAME)
XUI_HOST=<PANEL_SERVER_NAME>
XUI_BASE_PATH=/panel
XUI_SERVER_NAME=<PANEL_SERVER_NAME>

# Логин/пароль панели 3x-ui
# (настраивается внутри панели, НЕ nginx basic auth)
XUI_USERNAME=admin
XUI_PASSWORD=<пароль_панели_3x-ui>

# Порт подписок (из .env деплоя: VLESS_WS_UPSTREAM_PORT)
XUI_SUB_PORT=<VLESS_WS_UPSTREAM_PORT>
SUBSCRIPTION_URL_BASE=<PANEL_SERVER_NAME>

# SSL: True если XUI_API_URL использует https
XUI_VERIFY_SSL=False

# ID inbound в панели 3x-ui (раздел Inbounds)
INBOUND_ID=1

# === Reality (из панели 3x-ui: Inbounds → Reality) ===
REALITY_PUBLIC_KEY=<публичный_ключ>
REALITY_FINGERPRINT=chrome
REALITY_SNI=<sni>
REALITY_SHORT_ID=<short_id>
REALITY_SPIDER_X=/

# === Админ-панель Streamlit ===
ADMIN_PANEL_PASSWORD=<сильный_пароль>
ENABLE_CODE_EDITOR=false
